<Material>
    <Shaders>
        <Vertex Path="OTK.LiteUI.Assets.Shaders.VertexShaders.UIVShader.vert"/>
        <Fragment Path="OTK.LiteUI.Assets.Shaders.FragmentShaders.UIFShader.frag"/>
    </Shaders>

    <RenderState>
        <Blending Value="true"/>
        <CullFace Value="true"/>
        <DepthTest Value="false"/>
    </RenderState>
</Material>